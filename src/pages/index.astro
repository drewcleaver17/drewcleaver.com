---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: 'Starter',
    description:
      'A real email address on your own domain. firstname@firstnamelastname.com on ProtonMail. The smallest sovereign step — fast, clean, and a foundation you can build on.',
    deliverables: [
      'Domain registered in your name',
      'ProtonMail mailbox on your domain',
      'DNS, SPF, DKIM, DMARC configured',
      'Working inbox you control',
      '30-min handoff call',
    ],
  },
  {
    title: 'Standard',
    description:
      'A full privacy stack you actually use. Everything in Starter, plus VPN, password vault, hardened accounts, and the onboarding to make it stick.',
    deliverables: [
      'Everything in Starter',
      'ProtonVPN configured across your devices',
      'Password vault (Bitwarden or Proton Pass)',
      '2FA across critical accounts',
      'Onboarding guide written for you',
      '60-min training session',
      '30 days of async support',
    ],
    featured: true,
  },
  {
    title: 'Concierge',
    description:
      'Your stack, in your house. Everything in Standard, plus hardware-level sovereignty — your own router, your own DNS-level ad blocking, installed and configured on-site.',
    deliverables: [
      'Everything in Standard',
      'UniFi router (UDR7 or equivalent) at your home',
      'Pi-hole on Raspberry Pi 5 — network ad/tracker blocking',
      'Hardware included',
      'On-site installation (Austin metro)',
      'Network documentation written for you',
      '90 days of async support + 6-month check-in',
    ],
  },
];
---

<Base
  title="Home"
  description="Drew Cleaver — helping people own their corner of the internet. Domain, email, privacy, and home network sovereignty."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-16">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-teal)] mb-4">
      Inventor · Entrepreneur · Racing Driver · Futurist
    </p>
    <h1 class="text-4xl sm:text-5xl font-bold text-[var(--color-ink)] leading-tight mb-6">
      Tell me what you need.<br />
      Pay what it's worth to you.
    </h1>
    <p class="text-xl text-[var(--color-muted)] max-w-2xl leading-relaxed mb-10">
      I'm Drew Cleaver. I help people own their corner of the internet — your domain, your
      email, your privacy stack, and if you want to go all the way, the hardware that runs
      it all. No retainers, no lock-in, no subscription creep.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href="/contact"
        class="inline-block bg-[var(--color-teal)] text-white font-semibold text-sm px-6 py-3 rounded-lg hover:bg-[var(--color-teal-dark)] transition-colors"
      >
        Send an inquiry
      </a>
      <a
        href="/services"
        class="inline-block border border-[var(--color-border)] text-[var(--color-ink)] font-semibold text-sm px-6 py-3 rounded-lg hover:border-[var(--color-teal)] transition-colors"
      >
        See the menu
      </a>
    </div>
  </section>

  <!-- The pitch -->
  <section class="max-w-4xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
    <div class="grid sm:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-4">
          The internet used to be something you owned.
        </h2>
        <p class="text-[var(--color-muted)] leading-relaxed mb-4">
          Now most people rent it. They rent their email from Google, their identity from
          LinkedIn, their writing from Substack. One policy change away from being
          deplatformed. One acquisition away from being migrated.
        </p>
        <p class="text-[var(--color-muted)] leading-relaxed">
          I build the other thing. Boring, durable, yours. A real email address. A privacy
          stack that actually works. Hardware in your house if you want to go all the way.
          Infrastructure that outlives whatever app is hot this year.
        </p>
      </div>
      <div class="flex flex-col gap-4">
        {[
          { icon: '⚙️', label: 'Physical product startups' },
          { icon: '🤖', label: 'AI workflows & automation' },
          { icon: '📐', label: 'Digital sovereignty' },
          { icon: '🛒', label: 'E-commerce & Shopify' },
        ].map(({ icon, label }) => (
          <div class="flex items-center gap-3 text-sm text-[var(--color-ink)] font-medium">
            <span class="text-xl">{icon}</span>
            {label}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Three lanes -->
  <section class="max-w-4xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
    <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-2">Three lanes</h2>
    <p class="text-[var(--color-muted)] mb-8">
      Email, privacy stack, or full hardware. Pay what it's worth to you.
    </p>
    <div class="grid sm:grid-cols-3 gap-5">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
    <p class="text-sm text-[var(--color-muted)] mt-6">
      Need something custom? <a href="/contact" class="text-[var(--color-teal)] hover:underline">Tell me about it →</a>
    </p>
  </section>

  <!-- How pricing works -->
  <section class="max-w-4xl mx-auto px-6 py-12 border-t border-[var(--color-border)]">
    <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-4">
      How pricing works
    </h2>
    <p class="text-[var(--color-muted)] leading-relaxed mb-4">
      There's no price list. You read something I wrote, or someone sent you, or you're
      building the same kind of life I am. By the time you're filling out the form you've
      already done most of the qualifying.
    </p>
    <p class="text-[var(--color-muted)] leading-relaxed">
      Tell me what you need and what it's worth to you. If you're early and lean, pay less.
      If you're flush and want to support the work, pay more. The work and the standard
      don't change. I'd rather have you on the roster than not.
    </p>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-6 py-16 border-t border-[var(--color-border)]">
    <div class="bg-[var(--color-ink)] text-white rounded-2xl p-10 text-center">
      <h2 class="text-2xl font-bold mb-3">Ready to start?</h2>
      <p class="text-gray-400 mb-7 max-w-xl mx-auto">
        Tell me what you need and what it's worth to you. Two sentences is plenty. I read
        every inquiry and reply within a day or two.
      </p>
      <div class="flex flex-col items-center gap-3">
        <a
          href="/contact"
          class="inline-block bg-[var(--color-teal)] text-white font-semibold text-sm px-7 py-3 rounded-lg hover:bg-[var(--color-teal-dark)] transition-colors"
        >
          Send an inquiry
        </a>
        <a
          href="https://calendly.com/drewcleaver"
          class="text-sm text-gray-400 hover:text-white transition-colors"
        >
          Prefer a call first? Schedule one →
        </a>
      </div>
    </div>
  </section>
</Base>
