---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base
  title="Writing"
  description="Drew Cleaver's writing on digital sovereignty, AI workflows, physical product startups, and owning your stack."
>
  <section class="max-w-4xl mx-auto px-6 pt-16 pb-8">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-teal)] mb-3">
      Writing
    </p>
    <h1 class="text-4xl font-bold text-[var(--color-ink)] mb-4">
      Thinking out loud.
    </h1>
    <p class="text-xl text-[var(--color-muted)] max-w-xl leading-relaxed">
      On digital sovereignty, AI workflows, physical products, and building things
      that last. Irregular cadence. No newsletter.
    </p>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-10">
    {posts.length === 0 ? (
      <p class="text-[var(--color-muted)]">No posts yet. Check back soon.</p>
    ) : (
      <ul class="flex flex-col divide-y divide-[var(--color-border)]">
        {posts.map((post) => (
          <li>
            <a
              href={`/writing/${post.id}`}
              class="group flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 py-6 hover:text-[var(--color-teal)] transition-colors"
            >
              <div class="flex flex-col gap-1">
                <h2 class="font-semibold text-[var(--color-ink)] group-hover:text-[var(--color-teal)] transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-sm text-[var(--color-muted)] leading-relaxed">
                  {post.data.description}
                </p>
              </div>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-sm text-[var(--color-muted)] shrink-0 sm:ml-8"
              >
                {formatDate(post.data.pubDate)}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
